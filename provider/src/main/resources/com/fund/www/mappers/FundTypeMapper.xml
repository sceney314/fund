<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fund.www.provider.dao.FundTypeDao">
    <resultMap id="BaseResultMap" type="com.fund.www.provider.bean.po.FundType">
        <id column="id" jdbcType="INTEGER" property="id" />
        <result column="fund_id" jdbcType="VARCHAR" property="fundId" />
        <result column="sina_type_code" jdbcType="VARCHAR" property="sinaTypeCode" />
        <result column="type_name" jdbcType="VARCHAR" property="typeName" />
        <result column="is_use" jdbcType="TINYINT" property="isUse" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
    </resultMap>
    <sql id="Base_Column_List">
        id, fund_id, sina_type_code, type_name, is_use, create_time, update_time
    </sql>

    <!-- 添加基金类型 -->
    <insert id="addFundType" parameterType="com.fund.www.provider.bean.po.FundType" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `fund_type` (fund_id, sina_type_code, type_name, create_time)
        VALUES (#{fundId, jdbcType=VARCHAR}, #{sinaTypeCode, jdbcType=VARCHAR}, #{typeName, jdbcType=VARCHAR}, #{createTime, jdbcType=TIMESTAMP})
    </insert>

    <select id="getById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM `fund_type` WHERE id=#{id, jdbcType=INTEGER} AND is_use=1;
    </select>
</mapper>